# =============================================================================
# DailiCart Mobile App - Environment Configuration Template
# =============================================================================
# 
# INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual values
# 3. NEVER commit .env to git!
#
# =============================================================================

# =============================================================================
# SUPABASE (Required)
# =============================================================================
# Get these from: https://app.supabase.com → Your Project → Settings → API

EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key - ONLY for local seeding scripts, NEVER bundle in app
# Get from: Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# Direct DB connection - ONLY for migrations, NEVER bundle in app
SUPABASE_DB_URL=

# =============================================================================
# RAZORPAY PAYMENTS (Required for payments)
# =============================================================================
# Get these from: https://dashboard.razorpay.com → Settings → API Keys
# Use test keys (rzp_test_xxx) for development

EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# WARNING: Secret key should ONLY be used server-side (Edge Functions)
# Never expose this in mobile app bundle!
RAZORPAY_KEY_SECRET=

# =============================================================================
# APP CONFIGURATION
# =============================================================================

EXPO_PUBLIC_APP_NAME=DailiCart
EXPO_PUBLIC_APP_VERSION=1.0.0
EXPO_PUBLIC_APP_ENV=development

# =============================================================================
# DEVELOPMENT OPTIONS
# =============================================================================

# Dev mode: bypass auth and go directly to a role (ONLY works in __DEV__ builds)
# Options: 'selector' | 'customer' | 'admin' | 'distributor' | '' (normal auth flow)
EXPO_PUBLIC_DEV_MODE_ROLE=

# =============================================================================
# OPTIONAL SERVICES
# =============================================================================

# Sentry Error Tracking - https://sentry.io
EXPO_PUBLIC_SENTRY_DSN=

# Google Maps (for delivery tracking) - https://console.cloud.google.com
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Firebase (for push notifications) - https://console.firebase.google.com
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
